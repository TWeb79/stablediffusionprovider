# =============================================================================
# Stable Diffusion API Service - Environment Variables
# Author: Inventions4All - github:TWeb79
# =============================================================================
#
# This file documents all environment variables for the Stable Diffusion API.
# Copy to .env and adjust values for your environment.
#
# For Docker: Values are set in docker-compose.yml
# For local:  Values can be set in .env or passed directly
# =============================================================================

# -----------------------------------------------------------------------------
# API Configuration
# -----------------------------------------------------------------------------
API_HOST=0.0.0.0
API_PORT=8141
API_WORKERS=1

# -----------------------------------------------------------------------------
# Model Configuration
# -----------------------------------------------------------------------------
MODEL_DIR=/models
DEFAULT_MODEL=
SAFETY_CHECKER=false

# -----------------------------------------------------------------------------
# Device Configuration
# -----------------------------------------------------------------------------
# Compute device: cpu (Docker default), mps (Apple Silicon local), auto (prefer MPS)
DEVICE=cpu
ATTENTION_SLICING=true
CPU_OFFLOAD=true

# -----------------------------------------------------------------------------
# Threading Configuration (for CPU performance)
# -----------------------------------------------------------------------------
# Number of PyTorch threads (auto-detected if not set)
# TORCH_NUM_THREADS=8

# Number of inter-op threads (auto-detected if not set)
# TORCH_INTEROP_THREADS=4

# OpenMP thread count (auto-detected if not set)
# OMP_NUM_THREADS=8

# Intel MKL thread count (auto-detected if not set)
# MKL_NUM_THREADS=8

# -----------------------------------------------------------------------------
# Generation Defaults
# -----------------------------------------------------------------------------
DEFAULT_STEPS=25
DEFAULT_GUIDANCE=7.5
DEFAULT_WIDTH=512
DEFAULT_HEIGHT=512

# -----------------------------------------------------------------------------
# HuggingFace Token (optional, for gated models)
# -----------------------------------------------------------------------------
# HF_TOKEN=your_token_here

# -----------------------------------------------------------------------------
# Logging
# -----------------------------------------------------------------------------
LOG_LEVEL=INFO