# =============================================================================
# Stable Diffusion API Service - Environment Variables
# Author: Inventions4All - github:TWeb79
# =============================================================================

# API Configuration
API_HOST=0.0.0.0
API_PORT=8141
API_WORKERS=1

# Model Configuration
MODEL_DIR=/models
DEFAULT_MODEL=
SAFETY_CHECKER=false

# Device Configuration
DEVICE=cuda
ATTENTION_SLICING=true
CPU_OFFLOAD=false

# Generation Defaults
DEFAULT_STEPS=25
DEFAULT_GUIDANCE=7.5
DEFAULT_WIDTH=512
DEFAULT_HEIGHT=512

# HuggingFace Token (optional, for gated models)
# HF_TOKEN=your_token_here

# Logging
LOG_LEVEL=INFO